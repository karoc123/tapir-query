{
  "name": "tapir-query",
  "version": "0.1.0",
  "description": "Tapir:Query desktop SQL workbench for CSV exploration",
  "scripts": {
    "ng": "ng",
    "start": "CI=1 ng serve --host 127.0.0.1 --port 1420",
    "build": "ng build",
    "tauri:dev": "env -u LD_LIBRARY_PATH -u LD_PRELOAD -u GTK_PATH -u GIO_MODULE_DIR -u GTK_PATH_VSCODE_SNAP_ORIG -u GIO_MODULE_DIR_VSCODE_SNAP_ORIG WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1 LIBGL_ALWAYS_SOFTWARE=1 GSK_RENDERER=cairo tauri dev",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:ci": "jest --config jest.config.js --runInBand --coverage",
    "test:backend": "pnpm fixtures:pull && cd src-tauri && cargo test",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "rxjs": "~7.8",
    "tslib": "^2.8.1",
    "zone.js": "~0.15"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tauri-apps/cli": "^2",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.4",
    "tailwindcss": "^4.1.11",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3"
  }
}
